# AI 助手本地配置（权限、缓存、机器路径等只留本机，不跨工具同步、不入库）
.claude/
.agent/
.agents/
.codex/
.Codex/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# 模型/权重等大文件
*.pt
*.pth
*.weights
*.onnx

# 系统/编辑器
.DS_Store
.idea/
.vscode/
*.log

# 测试/lint/类型检查缓存
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage

# 模型存储目录(保留占位文件,权重仍被忽略)
models_store/*
!models_store/.gitkeep
templates_store/*
!templates_store/.gitkeep

# 本地环境变量(保留 .env.example 作为模板)
.env
!.env.example

# 资产配置:实际文件由用户从 .example 复制,不入库(保留 .example 模板)
configs/models.yaml
configs/templates.yaml

# uv 锁文件纳入版本管理(锁定依赖版本、保证可复现),不忽略

# 训练产物(教程生成,不入库)
runs/
training/demo_dataset/
