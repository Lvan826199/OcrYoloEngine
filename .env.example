# OcrYoloEngine 配置示例
# 复制为 .env 后按需修改;所有变量都有默认值,可只覆盖需要的项。
# 列表/布尔用 JSON 写法,例:OYE_API_KEYS=["k1","k2"]

# 设备:auto(有 GPU 用 GPU,否则 CPU)/ cpu / cuda
OYE_DEVICE=auto

# YOLO 默认置信度阈值(请求可覆盖)
OYE_DEFAULT_CONF_THRESHOLD=0.25

# 资产配置文件
OYE_MODELS_CONFIG_PATH=configs/models.yaml
OYE_TEMPLATES_CONFIG_PATH=configs/templates.yaml

# 模型 LRU 缓存上限(防显存/内存爆)
OYE_MODEL_CACHE_SIZE=3

# 并发:工作池线程数 / 排队上限(超出返回 503)/ 单请求超时(秒,超时 504)
OYE_MAX_WORKERS=4
OYE_MAX_QUEUE=32
OYE_REQUEST_TIMEOUT_S=30

# 输入上限:字节数 / 像素数(防内存打爆与 decompression bomb)
OYE_MAX_IMAGE_BYTES=10485760
OYE_MAX_IMAGE_PIXELS=16777216

# 安全:本地路径输入白名单(JSON 数组),为空则禁止用 path 传图
OYE_ALLOWED_PATH_ROOTS=[]

# 鉴权:允许的 API Key(JSON 数组),为空则关闭鉴权(本地友好)
OYE_API_KEYS=[]
